      "subtitles": [
        {
          "id": "sub_001",
          "time_start": 0.0,
          "time_end": 5.0,
          "text": "你缓缓睁开眼睛，发现自己身处一个陌生的房间。",
          "speaker": null
        },
        {
          "id": "sub_002",
          "time_start": 6.0,
          "time_end": 10.0,
          "text": "你是谁？这是哪里？",
          "speaker": "主角"
        },
        {
          "id": "sub_003",
          "time_start": 15.0,
          "time_end": 25.0,
          "text": "房间很简陋，窗户被遮住，门被反锁。你发现桌上有一张纸条。",
          "speaker": null
        },
        {
          "id": "sub_004",
          "time_start": 30.0,
          "time_end": 40.0,
          "text": "纸条上写着一串数字和一个地址：云海市，老张书店...",
          "speaker": null
        },
        {
          "id": "sub_005",
          "time_start": 50.0,
          "time_end": 60.0,
          "text": "突然，房间里的广播响起...",
          "speaker": null
        },
        {
          "id": "sub_006",
          "time_start": 65.0,
          "time_end": 80.0,
          "text": "你终于醒了。我没有太多时间解释，但你需要相信我——有人在追杀你。",
          "speaker": "神秘人"
        },
        {
          "id": "sub_007",
          "time_start": 85.0,
          "time_end": 100.0,
          "text": "门的密码是4927。出去后往东走，会有人接应你。这是你唯一的机会。",
          "speaker": "神秘人"
        }
      ],
      "choices": [
